window.init=function(){console.log("WG: init() entered");
  window.renderTargetMap&&window.renderTargetMap(TARGET.id);
  // Check if we have saved state for today
  var savedDate=localStorage.getItem('wg_date');
  var savedState=localStorage.getItem('wg_state');
  var savedStats=localStorage.getItem('wg_stats');

  // If we have a saved date that's NOT today, reset for new day
  if(savedDate&&savedDate!==TODAY){
    // Archive yesterday's result for stats if it existed
    if(savedState){
      try{
        var oldState=JSON.parse(savedState);
        // Stats were already saved at game end, so just reset state
      }catch(e){}
    }
    localStorage.removeItem('wg_state');
    localStorage.removeItem('wg_date');
    savedState=null;
    savedDate=null;
  }

  // If we have saved state for today, restore it
  // But if the saved target differs from current target, it's a reset — clear
  if(savedState&&savedDate===TODAY){
    try{
      var parsedState=JSON.parse(savedState);
      if(!parsedState._targetIdx||parsedState._targetIdx!==COUNTRIES.indexOf(TARGET)){
        // Country changed — reset
        savedState=null;
        localStorage.removeItem('wg_state');
        state=newState();
      } else {
        state=parsedState;
        // Restore keyboard state from guesses
        if(state.guesses){
          state.guesses.forEach(function(g){
            for(var i=0;i<g.name.length;i++){
              var ch=g.name[i];
              if(g.eval[i]==='green')kbState[ch]='green';
              else if(g.eval[i]==='yellow'&&(!kbState[ch]||kbState[ch]==='grey'))kbState[ch]='yellow';
              else if(!kbState[ch])kbState[ch]='grey';
            }
          });
        }
      }
    }catch(e){state=newState()}
  }else{
    state=newState()
  }

  localStorage.setItem('wg_date',TODAY);

  // Check if already completed today - show already-played state
  var stats=getStats();
  if(state.gameOver&&stats.lastPlayed===TODAY){
    showAlreadyPlayed();
  } else {
    // Show the game UI
    document.getElementById('game-content').style.display='flex';
    document.getElementById('already-played').style.display='none';
    resizeTiles();
    renderGrid();
    renderKB();
    if(state.gameOver)showEndScreen()
  }
}

// Show already-played state
function showAlreadyPlayed(){
  document.getElementById('game-content').style.display='none';
  var el=document.getElementById('already-played');
  el.style.display='flex';

  // Check if they completed it
  var stats=getStats();
  var lastPlayed=stats.lastPlayed;

  if(state.won){
    document.getElementById('admire-msg').textContent='You found it in '+state.guesses.length+'/5 guesses!';
  } else {
    document.getElementById('admire-msg').textContent='You didn\'t get it this time.';
  }
  document.getElementById('admire-flag').textContent=TARGET.flag;
}

// Show admire view - completed grid + answer
function showAdmireView(){
  var el=document.getElementById('already-played');
  el.style.display='none';
  var av=document.getElementById('admire-view');
  av.classList.add('show');
  document.getElementById('admire-flag2').textContent=TARGET.flag;
  document.getElementById('admire-country2').textContent=TARGET.name;

  // Build the completed grid
  var grid=document.getElementById('admire-grid');
  grid.innerHTML='';
  state.guesses.forEach(function(g){
    var row=document.createElement('div');
    row.className='grid-row';
    for(var i=0;i<g.name.length;i++){
      var t=document.createElement('div');
      t.className='tile '+g.eval[i]+' flip';
      t.innerHTML='<div class="tile-inner"><span class="tile-front">'+g.name[i]+'</span><div class="tile-back">'+g.name[i]+'</div></div>';
      row.appendChild(t);
    }
    grid.appendChild(row);
  });
  resizeTiles();
}

// Hide admire view and go back to already-played
function hideAdmireView(){
  document.getElementById('admire-view').classList.remove('show');
  document.getElementById('already-played').style.display='flex';
}
function newState(){return{guesses:[],current:'',gameOver:false,won:false,_targetIdx:COUNTRIES.indexOf(TARGET)}}
function hav(l1,o1,l2,o2){var R=6371;var d1=(l2-l1)*Math.PI/180;var d2=(o2-o1)*Math.PI/180;var a=Math.sin(d1/2)*Math.sin(d1/2)+Math.cos(l1*Math.PI/180)*Math.cos(l2*Math.PI/180)*Math.sin(d2/2)*Math.sin(d2/2);return R*2*Math.atan2(Math.sqrt(a),Math.sqrt(1-a))}
function bear(l1,o1,l2,o2){var y=Math.sin((o2-o1)*Math.PI/180)*Math.cos(l2*Math.PI/180);var x=Math.cos(l1*Math.PI/180)*Math.sin(l2*Math.PI/180)-Math.sin(l1*Math.PI/180)*Math.cos(l2*Math.PI/180)*Math.cos((o2-o1)*Math.PI/180);return((Math.atan2(y,x)*180/Math.PI)+360)%360}
function getDirIdx(l1,o1,l2,o2){return Math.round(bear(l1,o1,l2,o2)/45)%8}
function distLabel(km){if(km<500)return'Very close!';if(km<2000)return'Getting warm';if(km<5000)return'Mid-range';if(km<10000)return'Far';return'Very far'}
function evaluate(g,t){var gr=g.toUpperCase().split(''),tr=t.toUpperCase().split(''),res=gr.map(function(){return'grey'}),tc=[].concat(tr);for(var i=0;i<gr.length;i++)if(gr[i]===tc[i]){res[i]='green';tc[i]=null}for(var i=0;i<gr.length;i++)if(res[i]!=='green'){var j=tc.indexOf(gr[i]);if(j!==-1){res[i]='yellow';tc[j]=null}}return res}
function submitGuess(){var g=state.current.trim().toUpperCase();if(!g)return;var guessNorm=g.replace(/ /g,'');if(guessNorm.length!==TARGET.normalizedName.length){toast('This country has '+TARGET.name.length+' letters');return}var c=null;for(var i=0;i<COUNTRIES.length;i++)if(COUNTRIES[i].normalizedName===guessNorm){c=COUNTRIES[i];break}if(!c){toast('Not in country list');return}var ev=evaluate(g,TARGET.name),km=Math.round(hav(c.lat,c.lon,TARGET.lat,TARGET.lon)),di=getDirIdx(c.lat,c.lon,TARGET.lat,TARGET.lon);state.guesses.push({name:g,eval:ev,km:km,di:di,flag:c.flag,_targetIdx:COUNTRIES.indexOf(TARGET)});state._targetIdx=COUNTRIES.indexOf(TARGET);for(var i=0;i<g.length;i++){var ch=g[i];if(ev[i]==='green')kbState[ch]='green';else if(ev[i]==='yellow'&&kbState[ch]!=='green')kbState[ch]='yellow';else if(!kbState[ch])kbState[ch]='grey'}state.current='';saveState();renderGrid();renderKB();var row=state.guesses.length-1;setTimeout(function(){revealRow(row)},80);if(guessNorm===TARGET.normalizedName){setTimeout(function(){state.won=true;state.gameOver=true;saveState();showEndScreen()},TARGET.normalizedName.length*300+400)}else if(state.guesses.length>=5){setTimeout(function(){state.gameOver=true;saveState();showEndScreen()},TARGET.normalizedName.length*300+400)}}
function revealRow(row){var g=state.guesses[row];document.querySelectorAll('.tile-row[data-row="'+row+'"] .tile').forEach(function(c,i){setTimeout(function(){c.classList.add(g.eval[i],'flip');if(g.eval[i]==='green')c.style.boxShadow='0 0 14px var(--green)'},i*300)});var geoEl=document.querySelector('.geo-mini[data-row="'+row+'"]');if(geoEl){setTimeout(function(){geoEl.classList.add('revealed');var arrEl=geoEl.querySelector('.darr');var distEl=geoEl.querySelector('.ddist');if(arrEl)arrEl.textContent=ARROWS[g.di];if(distEl)distEl.textContent=g.km.toLocaleString()+' km \u2014 '+distLabel(g.km)},TARGET_LEN*300+80)}}
function showEndScreen(){if(state.won){var n=state.guesses.length,t=['','Perfect!','Brilliant!','Great!','Nice!','Phew!','Close one!'];document.getElementById('win-title').textContent=t[n]||'Got it!';document.getElementById('win-sub').textContent='You found '+TARGET.name+' in '+n+'/5 guesses.';document.getElementById('win-flag').textContent=TARGET.flag;document.getElementById('win-fact').textContent=TARGET.flag+' '+TARGET.funFact;buildShare('win-share',true);updateStats(true,n);document.getElementById('win-modal').classList.add('show')}else{document.getElementById('loss-sub').textContent='The answer was '+TARGET.flag+' '+TARGET.name+'.';document.getElementById('loss-flag').textContent=TARGET.flag;document.getElementById('loss-fact').textContent=TARGET.funFact;buildShare('loss-share',false);updateStats(false,0);document.getElementById('loss-modal').classList.add('show')}}
function buildShare(elId,won){var el=document.getElementById(elId),text='WORDOGRAPHY '+(won?state.guesses.length:'X')+'/5\n';state.guesses.forEach(function(g){g.eval.forEach(function(e){text+=e==='green'?'\ud83d\udfe7':e==='yellow'?'\ud83d\udfe8':'\u2b1b'});text+='\n'});var last=state.guesses[state.guesses.length-1];if(last)text+='\ud83d\udccd '+last.km.toLocaleString()+' km\n';el.textContent=text}
function toast(msg){var t=document.getElementById('toast');t.textContent=msg;t.classList.add('show');setTimeout(function(){t.classList.remove('show')},2000)}
function saveState(){localStorage.setItem('wg_state',JSON.stringify(state))}
function getStats(){var s=localStorage.getItem('wg_stats');return s?JSON.parse(s):{played:0,won:0,currentStreak:0,maxStreak:0,guessDistribution:[0,0,0,0,0,0],lastPlayed:null}}
function saveStats(s){localStorage.setItem('wg_stats',JSON.stringify(s))}
function renderStats(){
  var s=getStats(),pct=s.played?Math.round(s.won/s.played*100):0;
  var html='<div class="stat-box"><div class="num">'+s.played+'</div><div class="lbl">Played</div></div>';
  html+='<div class="stat-box"><div class="num">'+pct+'</div><div class="lbl">Win %</div></div>';
  html+='<div class="stat-box"><div class="num">'+s.currentStreak+'</div><div class="lbl">Streak</div></div>';
  html+='<div class="stat-box"><div class="num">'+s.maxStreak+'</div><div class="lbl">Best</div></div>';
  document.getElementById('stats-grid').innerHTML=html;
}
function updateStats(won,guessCount){
  var s=getStats();
  s.played++;
  s.lastPlayed=TODAY;
  if(won){s.won++;s.currentStreak++;s.maxStreak=Math.max(s.currentStreak,s.maxStreak);if(guessCount>=1&&guessCount<=6){s.guessDistribution[guessCount-1]++}}else{s.currentStreak=0}saveStats(s)
}
function renderGrid(){var g=document.getElementById('grid');g.innerHTML='';for(var row=0;row<5;row++){var wrap=document.createElement('div');wrap.className='grid-row-wrap';var geo=document.createElement('div');geo.className='geo-mini';geo.setAttribute('data-row',row);if(row<state.guesses.length){geo.classList.add('revealed');geo.innerHTML='<span class="darr">'+ARROWS[state.guesses[row].di]+'</span><span class="ddist">'+state.guesses[row].km.toLocaleString()+' km \u2014 '+distLabel(state.guesses[row].km)+'</span>'}wrap.appendChild(geo);var rowDiv=document.createElement('div');rowDiv.className='grid-row tile-row';rowDiv.setAttribute('data-row',row);for(var i=0;i<TARGET_LEN;i++){var t=document.createElement('div');t.className='tile';if(row<state.guesses.length){t.classList.add(state.guesses[row].eval[i]);t.innerHTML='<div class="tile-inner"><span class="tile-front">'+state.guesses[row].name[i]+'</span><div class="tile-back">'+state.guesses[row].name[i]+'</div></div>'}else if(row===state.guesses.length&&i<state.current.length){t.textContent=state.current[i].toUpperCase();t.classList.add('current')}rowDiv.appendChild(t)}wrap.appendChild(rowDiv);g.appendChild(wrap)}}
function renderKB(){var kb=document.getElementById('keyboard');kb.innerHTML='';var rows=['QWERTYUIOP','ASDFGHJKL','ZXCVBNM'];rows.forEach(function(row,i){var r=document.createElement('div');r.className='krow';if(i===2){var del=document.createElement('button');del.className='key wide';del.textContent='⌫';del.onclick=function(){state.current=state.current.slice(0,-1);renderGrid()};r.appendChild(del)}var letters=row.split('');letters.forEach(function(ch){var k=document.createElement('button');k.className='key';if(kbState[ch]==='green')k.classList.add('green');else if(kbState[ch]==='yellow')k.classList.add('yellow');else if(kbState[ch]==='grey')k.classList.add('grey');k.textContent=ch;k.onclick=function(){if(state.gameOver)return;if(state.current.length<TARGET_LEN){state.current+=ch;renderGrid()}};r.appendChild(k)});if(i===2){var en=document.createElement('button');en.className='key wide';en.textContent='ENTER';en.onclick=submitGuess;r.appendChild(en)}kb.appendChild(r)});var spaceRow=document.createElement('div');spaceRow.className='krow';var spaceKey=document.createElement('button');spaceKey.className='key space-key';spaceKey.textContent='_';if(kbState[' ']==='green')spaceKey.classList.add('green');else if(kbState[' ']==='yellow')spaceKey.classList.add('yellow');else if(kbState[' ']==='grey')spaceKey.classList.add('grey');spaceKey.onclick=function(){if(state.gameOver)return;if(state.current.length<TARGET_LEN){state.current+=' ';renderGrid()}};spaceRow.appendChild(spaceKey);kb.appendChild(spaceRow)}
document.addEventListener('keydown',function(e){
  if(state.gameOver)return;
  var k=e.key.toUpperCase();
  if(k==='ENTER'||k==='RETURN'){e.preventDefault();submitGuess()}
  else if(k==='BACKSPACE'){e.preventDefault();state.current=state.current.slice(0,-1);renderGrid()}
  else if((k.length===1&&k>='A'&&k<='Z'||k===' ')&&state.current.length<TARGET_LEN){state.current+=k;renderGrid()}
});


var isDark=true;document.getElementById('theme-btn').onclick=function(){isDark=!isDark;document.documentElement.setAttribute('data-theme',isDark?'light':'');document.getElementById('theme-btn').innerHTML=isDark?'☾':'☀'};
var cbMode=false;document.getElementById('cb-btn').onclick=function(){cbMode=!cbMode;document.documentElement.setAttribute('data-cb',cbMode?'on':'')};
document.getElementById('stats-btn').onclick=function(){renderStats();document.getElementById('stats-modal').classList.add('show')};
document.getElementById('help-btn').onclick=function(){document.getElementById('help-modal').classList.add('show')};
document.getElementById('help-close').onclick=function(){document.getElementById('help-modal').classList.remove('show')};
document.querySelectorAll('.modal-overlay').forEach(function(m){m.querySelector('.close').onclick=function(){m.classList.remove('show')};m.onclick=function(e){if(e.target===m)m.classList.remove('show')}});
document.getElementById('win-copy').onclick=function(){navigator.clipboard.writeText(document.getElementById('win-share').textContent).then(function(){toast('Copied!')})};
document.getElementById('loss-copy').onclick=function(){navigator.clipboard.writeText(document.getElementById('loss-share').textContent).then(function(){toast('Copied!')})};
function resizeTiles(){document.documentElement.style.setProperty('--tl',TARGET_LEN);}
window.addEventListener('resize',resizeTiles);
resizeTiles();
console.log('WG: init about to run');
try { init(); console.log('WG: init() OK'); } catch(e) { console.error('WG: init() FAILED:', e.message, e.stack); }
</script>
</body>
</html>
